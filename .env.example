# ============================================
# Math Battle - 環境変数サンプル
# ============================================
# このファイルをコピーして .env.local を作成してください:
#   cp .env.example .env.local
#
# Vercelにデプロイする際は、Vercel管理画面の
# Settings → Environment Variables に同じ値を設定してください。
# ============================================

# --- WebSocket接続先 (必須) ---
# 本番: wss://mathbattle-ws.onrender.com
# ローカル: 空欄でOK (localhost:1999 に自動フォールバック)
NEXT_PUBLIC_WS_URL=

# --- 公開サイトURL (OGP・シェア用、必須) ---
# 例: https://mathbattle.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Google Analytics 4 (任意) ---
# GA4管理画面 → 管理 → データストリーム → ストリームID
# 形式: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# --- Sentry (任意) ---
# Sentry管理画面 → Settings → Projects → Client Keys (DSN)
# 形式: https://xxxxxx@oxxxxxx.ingest.sentry.io/xxxxxxx
NEXT_PUBLIC_SENTRY_DSN=

# --- Google AdSense (任意) ---
# AdSense管理画面 → アカウント → 設定 → アカウント情報 → サイト運営者ID
# 形式: ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# AdSenseの広告ユニットID (3箇所)
# AdSense管理画面 → 広告 → 広告ユニットごと で発行
# 形式: XXXXXXXXXX (10桁の数字)
NEXT_PUBLIC_ADSENSE_SLOT_LOBBY=
NEXT_PUBLIC_ADSENSE_SLOT_WAITING=
NEXT_PUBLIC_ADSENSE_SLOT_RESULT=

# --- Buy Me a Coffee (任意) ---
# 例: https://www.buymeacoffee.com/yourname
NEXT_PUBLIC_BMC_URL=
