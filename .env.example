# --- フロントエンド (Vercel) ---
# WebSocketサーバーのURL。RenderにデプロイしたWSサーバーのURLを指定する。
# 例: wss://mathbattle-ws.onrender.com
# (末尾スラッシュ不要。/room/<roomId> はクライアントが自動で付加する)
NEXT_PUBLIC_WS_URL=

# --- (オプション・後方互換) ---
# NEXT_PUBLIC_WS_URL が無い場合に使われる。host:port 形式で wss が自動付与される
# NEXT_PUBLIC_PARTYKIT_HOST=

# --- Supabase (将来用、現時点では未実装) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
